# Joystream FM – Serverkonfiguration

# Verzeichnis-Listing verbieten
Options -Indexes

# db.php vor direktem Zugriff schützen
<Files "db.php">
    Order Allow,Deny
    Deny from all
</Files>

# test.php und setup.php schützen (nach Nutzung aktivieren)
# <Files "test.php">
#     Order Allow,Deny
#     Deny from all
# </Files>
# <Files "setup.php">
#     Order Allow,Deny
#     Deny from all
# </Files>
